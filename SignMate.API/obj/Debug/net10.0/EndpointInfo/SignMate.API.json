        "type": "object",
        "properties": {
          "signId": {
            "type": "string",
            "format": "uuid"
          },
          "isMastered": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
